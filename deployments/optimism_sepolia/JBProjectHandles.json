	"metadata": "{\"compiler\":{\"version\":\"0.8.28+commit.7893614a\"},\"language\":\"Solidity\",\"output\":{\"abi\":[{\"inputs\":[{\"internalType\":\"address\",\"name\":\"trustedForwarder\",\"type\":\"address\"}],\"stateMutability\":\"nonpayable\",\"type\":\"constructor\"},{\"inputs\":[{\"internalType\":\"string[]\",\"name\":\"parts\",\"type\":\"string[]\"}],\"type\":\"error\",\"name\":\"JBProjectHandles_EmptyNamePart\"},{\"inputs\":[{\"internalType\":\"string[]\",\"name\":\"parts\",\"type\":\"string[]\"}],\"type\":\"error\",\"name\":\"JBProjectHandles_EthPartNotAllowed\"},{\"inputs\":[{\"internalType\":\"string\",\"name\":\"part\",\"type\":\"string\"}],\"type\":\"error\",\"name\":\"JBProjectHandles_InvalidNamePart\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"chainId\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"projectId\",\"type\":\"uint256\"},{\"internalType\":\"address\",\"name\":\"caller\",\"type\":\"address\"}],\"type\":\"error\",\"name\":\"JBProjectHandles_NoParts\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"chainId\",\"type\":\"uint256\",\"indexed\":true},{\"internalType\":\"uint256\",\"name\":\"projectId\",\"type\":\"uint256\",\"indexed\":true},{\"internalType\":\"string\",\"name\":\"handle\",\"type\":\"string\",\"indexed\":false},{\"internalType\":\"string[]\",\"name\":\"parts\",\"type\":\"string[]\",\"indexed\":false},{\"internalType\":\"address\",\"name\":\"caller\",\"type\":\"address\",\"indexed\":false}],\"type\":\"event\",\"name\":\"SetEnsNameParts\",\"anonymous\":false},{\"inputs\":[],\"stateMutability\":\"view\",\"type\":\"function\",\"name\":\"ENS_REGISTRY\",\"outputs\":[{\"internalType\":\"contract ENS\",\"name\":\"\",\"type\":\"address\"}]},{\"inputs\":[],\"stateMutability\":\"view\",\"type\":\"function\",\"name\":\"TEXT_KEY\",\"outputs\":[{\"internalType\":\"string\",\"name\":\"\",\"type\":\"string\"}]},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"chainId\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"projectId\",\"type\":\"uint256\"},{\"internalType\":\"address\",\"name\":\"setter\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\",\"name\":\"ensNamePartsOf\",\"outputs\":[{\"internalType\":\"string[]\",\"name\":\"\",\"type\":\"string[]\"}]},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"chainId\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"projectId\",\"type\":\"uint256\"},{\"internalType\":\"address\",\"name\":\"setter\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\",\"name\":\"handleOf\",\"outputs\":[{\"internalType\":\"string\",\"name\":\"\",\"type\":\"string\"}]},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"forwarder\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\",\"name\":\"isTrustedForwarder\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}]},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"chainId\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"projectId\",\"type\":\"uint256\"},{\"internalType\":\"string[]\",\"name\":\"parts\",\"type\":\"string[]\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\",\"name\":\"setEnsNamePartsFor\"},{\"inputs\":[],\"stateMutability\":\"view\",\"type\":\"function\",\"name\":\"trustedForwarder\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}]}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{\"constructor\":{\"params\":{\"trustedForwarder\":\"The trusted forwarder for the ERC2771Context.\"}},\"ensNamePartsOf(uint256,uint256,address)\":{\"params\":{\"chainId\":\"The chain ID of the network on which the project ID exists.\",\"projectId\":\"The ID of the project to get the ENS name of.\",\"setter\":\"The address that set the requested record in this contract.\"},\"returns\":{\"_0\":\"The parts of the ENS name of a project.\"}},\"handleOf(uint256,uint256,address)\":{\"details\":\"Verified means the ENS text record with `TEXT_KEY` contains `chainId:projectId`.\",\"params\":{\"chainId\":\"The chain ID of the network the project is on.\",\"projectId\":\"The ID of the project to get the handle of.\",\"setter\":\"The address which set the requested handle.\"},\"returns\":{\"_0\":\"handle The project's verified handle.\"}},\"isTrustedForwarder(address)\":{\"details\":\"Indicates whether any particular address is the trusted forwarder.\"},\"setEnsNamePartsFor(uint256,uint256,string[])\":{\"details\":\"The `parts` [\\\"jbx\\\", \\\"dao\\\", \\\"foo\\\"] represents foo.dao.jbx.eth.Callers must provide ENS-normalized names (lowercase, ENSIP-15). ASCII control characters, DEL, and dots are rejected here; higher-byte Unicode (invisible codepoints like U+2060, the Tags block, etc.) is NOT filtered onchain because an onchain denylist cannot be complete and a partial one is a false safety signal. Clients must apply ENSIP-15 normalization off-chain before trusting a returned handle.\",\"params\":{\"chainId\":\"The chain ID of the network the project is on.\",\"parts\":\"The parts of the ENS domain to use as the project handle, excluding the trailing .eth.\",\"projectId\":\"The ID of the project to set an ENS handle for.\"}},\"trustedForwarder()\":{\"details\":\"Returns the address of the trusted forwarder.\"}},\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"ENS_REGISTRY()\":{\"notice\":\"The ENS registry contract address.\"},\"TEXT_KEY()\":{\"notice\":\"The key of the ENS text record which points back to a project.\"},\"ensNamePartsOf(uint256,uint256,address)\":{\"notice\":\"The parts of the stored ENS name of a project.\"},\"handleOf(uint256,uint256,address)\":{\"notice\":\"Returns a project's verified handle, or the empty string if unverified.\"},\"setEnsNamePartsFor(uint256,uint256,string[])\":{\"notice\":\"Point from a Juicebox project to an ENS node.\"}},\"version\":1}},\"settings\":{\"remappings\":[\"@arbitrum/=node_modules/@arbitrum/\",\"@ballkidz/=node_modules/@ballkidz
{
  "name": "@bananapus/deploy-all-v6",
  "version": "0.0.48",
  "license": "MIT",
  "description": "One-shot deployment orchestrator for the Juicebox V6 ecosystem.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bananapus/deploy-all-v6.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "foundry.toml",
    "references/",
    "remappings.txt",
    "script/"
  ],
  "scripts": {
    "build": "forge build",
    "postinstall": "patch-package",
    "artifacts": "./script/build-artifacts.sh",
    "deploy:propose:testnets": "DEFIFA_REV_START_TIME=$(($(date +%s) + 86400)) npx sphinx propose script/Deploy.s.sol --networks testnets",
    "deploy:propose:mainnets": "DEFIFA_REV_START_TIME=$(($(date +%s) + 86400)) npx sphinx propose script/Deploy.s.sol --networks mainnets",
    "deploy:propose:banny-drops:testnets": "npx sphinx propose script/DeployBannyDrops.s.sol --networks testnets",
    "deploy:propose:banny-drops:mainnets": "npx sphinx propose script/DeployBannyDrops.s.sol --networks mainnets",
    "deploy:propose:live-smoke:testnets": "npx sphinx propose script/LivePostDeploySmoke.s.sol --networks testnets",
    "deploy:propose:live-smoke:mainnets": "npx sphinx propose script/LivePostDeploySmoke.s.sol --networks mainnets",
    "deploy:post": "./script/post-deploy.sh",
    "deploy:post:testnets": "./script/post-deploy.sh --chains=all-testnets",
    "deploy:post:mainnets": "./script/post-deploy.sh --chains=all-mainnets",
    "deploy:post:verify-only": "./script/post-deploy.sh --chains=all-testnets --skip-artifacts --skip-distribute",
    "deploy:post:artifacts-only": "./script/post-deploy.sh --chains=all-testnets --skip-verify"
  },
  "dependencies": {
    "@arbitrum/nitro-contracts": "3.2.0",
    "@ballkidz/defifa": "^0.0.49",
    "@bananapus/721-hook-v6": "^0.0.59",
    "@bananapus/address-registry-v6": "^0.0.29",
    "@bananapus/buyback-hook-v6": "^0.0.62",
    "@bananapus/core-v6": "^0.0.73",
    "@bananapus/distributor-v6": "^0.0.32",
    "@bananapus/omnichain-deployers-v6": "^0.0.52",
    "@bananapus/permission-ids-v6": "^0.0.27",
    "@bananapus/project-handles-v6": "^0.0.21",
    "@bananapus/project-payer-v6": "^0.0.19",
    "@bananapus/referral-split-hook-v6": "^0.0.7",
    "@bananapus/router-terminal-v6": "^0.0.56",
    "@bananapus/suckers-v6": "^0.0.61",
    "@bananapus/univ4-lp-split-hook-v6": "^0.0.51",
    "@bananapus/univ4-router-v6": "^0.0.46",
    "@bannynet/core-v6": "^0.0.41",
    "@chainlink/contracts": "1.5.0",
    "@chainlink/contracts-ccip": "1.6.4",
    "@croptop/core-v6": "^0.0.60",
    "@openzeppelin/contracts": "5.6.1",
    "@openzeppelin/uniswap-hooks": "1.1.1",
    "@rev-net/core-v6": "^0.0.79",
    "@uniswap/permit2": "github:Uniswap/permit2#cc56ad0f3439c502c246fc5cfcc3db92bb8b7219",
    "@uniswap/v3-core": "github:Uniswap/v3-core#6562c52e8f75f0c10f9deaf44861847585fc8129",
    "@uniswap/v3-periphery": "github:Uniswap/v3-periphery#b325bb0905d922ae61fcc7df85ee802e8df5e96c",
    "@uniswap/v4-core": "1.0.2",
    "@uniswap/v4-periphery": "1.0.3",
    "base64-sol": "1.1.0",
    "solady": "0.1.26"
  },
  "devDependencies": {
    "@sphinx-labs/plugins": "0.33.3",
    "patch-package": "8.0.1"
  }
}
